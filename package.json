{
  "name": "ebenezer",
  "version": "1.0.0",
  "description": "Website for Iglesia de Dios Ebenezer based in Snellville, GA",
  "main": "server/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node .",
    "flow": "flow",
    "build": "rm -rf dist && webpack",
    "compile": "npm run compile-server && npm run compile-react",
    "compile-server": "babel src/server -d server",
    "compile-react": "babel src/components -d public/components",
    "reload": "npm run compile && npm run build && npm start"
  },
