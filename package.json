    "@emotion/react": "^11.7.1",
    "@emotion/styled": "^11.6.0",
    "@mui/lab": "^5.0.0-alpha.63",
    "@mui/material": "^5.2.7",
    "babel-loader": "^8.2.2",
    "babel-preset-react-app": "^3.1.2",
    "bootstrap": "^5.0.0-beta3",
    "cors": "^2.8.5",
    "express": "^4.17.1",
    "html-loader": "^2.1.2",
